{
  "name": "@dhando/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --external:electron --external:better-sqlite3 && esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron",
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on http://localhost:5273 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "electron": "electron .",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dhando/core": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^16.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^25.0.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.0",
    "wait-on": "^8.0.0"
  }
}

{
  "name": "@dhando/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Dhando Analyzer — Dalio-style investment analysis desktop app",
  "author": "Alex Nelja",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --external:electron --external:better-sqlite3 && esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron",
    "dev": "npm run build:main && concurrently \"vite\" \"wait-on http://localhost:5274 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "electron": "electron .",
    "clean": "rm -rf dist release",
    "rebuild:electron": "node scripts/rebuild-sqlite.mjs electron",
    "rebuild:node": "node scripts/rebuild-sqlite.mjs node",
    "predev": "pnpm run rebuild:electron",
    "pretest": "pnpm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "pnpm run rebuild:electron && pnpm run build && electron-builder --dir",
    "dist": "pnpm run rebuild:electron && pnpm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0"
  },
  "devDependencies": {
    "@dhando/core": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.dhando.analyzer",
    "productName": "Dhando Analyzer",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/*.node"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
